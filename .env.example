# ── Frontend (Vite) ──────────────────────────────────────────────
# Firebase Web SDK config (Firebase Console > Project settings > Your apps > Web app)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Comma-separated allowlist of admin emails (client-side gate).
VITE_ADMIN_EMAILS=admin@example.com
# Backend API base URL.
VITE_API_BASE_URL=http://127.0.0.1:8787

# ── Backend (Node server) ────────────────────────────────────────
# Admin allowlist enforced server-side (must include the same emails).
ADMIN_EMAILS=admin@example.com
ALLOWED_ORIGINS=http://127.0.0.1:5173,https://sanghakbae.github.io

# Firebase Admin credentials — pick ONE of the following:
# 1) Inline service-account JSON (recommended for Render / hosted):
FIREBASE_SERVICE_ACCOUNT=
# 2) Path to a service-account key file:
# FIREBASE_SERVICE_ACCOUNT_PATH=./backend/firebase-service-account.json
# (FIREBASE_PROJECT_ID is optional; it is read from the service account when present.)
FIREBASE_PROJECT_ID=

# Image storage stays on Cloudflare R2 (leave blank to use local disk).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=
